// ============================================================================
// Prisma Schema - Créditos Lopest
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// CLIENTES
// ============================================================================

model Cliente {
  id String @id @default(cuid())

  cedula String @unique
  nombre String

  direccion  String?
  empresa    String?
  telefono   String?
  recomienda String?
  contacto   String?
  contacto2  String?

  carpetaAdjuntosUrl String?
  estadoDocumentos   EstadoDocumentos @default(FALTAN_DOCUMENTOS)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  accionPor     String?

  creditos   Credito[]
  documentos DocumentoCliente[]

  // Propietario principal/documental del cliente.
  // Importante: la cartera financiera por credito vive en Credito.ownerUserId.
  ownerUserId String?
  ownerUser   User? @relation("ClienteOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@index([ownerUserId])
  @@index([nombre])
  @@index([telefono])
  @@map("clientes")
}

// ============================================================================
// CRÉDITOS
// ============================================================================

model Credito {
  id String @id @default(cuid())

  codigo String @unique
  idempotencyKey String? @unique

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Restrict)

  // Propietario operativo/financiero del credito.
  // Permite que un mismo cliente sea compartido entre cuentas con creditos distintos.
  ownerUserId String?
  ownerUser   User? @relation("CreditoOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  fechaPrestamo DateTime

  monto       Decimal @db.Decimal(18, 2)
  plazoMeses  Decimal @db.Decimal(10, 2)
  tasaMensual Decimal @db.Decimal(10, 6)

  frecuencia       FrecuenciaPago
  tipoAmortizacion TipoAmortizacion @default(AMORTIZACION_FIJA)

  estado EstadoCredito @default(ACTIVO)

  observaciones String?
  nota          String?

  fechaCancelacion DateTime?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  accionPor     String?

  eventos EventoFinanciero[]

  @@index([clienteId])
  @@index([ownerUserId])
  @@index([codigo])
  @@index([estado])
  @@index([fechaPrestamo])
  @@map("creditos")
}

// ============================================================================
// EVENTOS FINANCIEROS
// ============================================================================

model EventoFinanciero {
  id String @id @default(cuid())

  codigo String @unique

  creditoId String
  credito   Credito @relation(fields: [creditoId], references: [id], onDelete: Cascade)

  numeroCuota Int?

  tipo TipoEventoFinanciero @default(CUOTA_PROGRAMADA)

  fechaProgramada DateTime
  fechaPago       DateTime?

  valorProgramado   Decimal @db.Decimal(18, 2)
  capitalProgramado Decimal @db.Decimal(18, 2)
  interesProgramado Decimal @db.Decimal(18, 2)

  montoPagado   Decimal @default(0) @db.Decimal(18, 2)
  capitalPagado Decimal @default(0) @db.Decimal(18, 2)
  interesPagado Decimal @default(0) @db.Decimal(18, 2)

  saldoCapitalPost Decimal? @db.Decimal(18, 2)

  estado EstadoEventoFinanciero @default(PENDIENTE)

  diasAtraso Int @default(0)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  accionPor     String?

  @@index([creditoId])
  @@index([tipo])
  @@index([estado])
  @@index([fechaProgramada])
  @@index([fechaPago])
  @@index([creditoId, numeroCuota])
  @@map("eventos_financieros")
}

model SecuenciaCredito {
  id String @id @default(cuid())

  anio Int @unique
  ultimoNumero Int @default(0)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("secuencias_credito")
}

model DocumentoCliente {
  id String @id @default(cuid())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  nombreArchivo String
  mimeType      String?
  tamanoBytes   Int?

  url String

  driveFileId   String? @unique
  driveFolderId String?

  proveedor ProveedorArchivo @default(GOOGLE_DRIVE)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  accionPor     String?

  @@index([clienteId])
  @@index([driveFileId])
  @@index([driveFolderId])
  @@map("documentos_cliente")
}

// ============================================================================
// AUTENTICACIÓN, ROLES Y AUDITORÍA
// ============================================================================

model User {
  id String @id @default(cuid())

  email String @unique
  nombre String

  passwordHash String?
  photoUrl String?
  lastLoginAt DateTime?

  activo Boolean @default(true)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  roles    UserRole[]
  oauthAccounts OauthAccount[]
  auditLogs AuditLog[] @relation("AuditActor")

  clientesPropios Cliente[] @relation("ClienteOwner")
  creditosPropios Credito[] @relation("CreditoOwner")

  @@index([email])
  @@index([activo])
  @@map("users")
}

model Role {
  id String @id @default(cuid())

  code String @unique
  name String

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  creadoEn DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model OauthAccount {
  id String @id @default(cuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider String
  providerAccountId String

  email String
  emailVerified Boolean @default(false)

  pictureUrl String?

  creadoEn DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@unique([provider, email])
  @@index([userId])
  @@index([email])
  @@map("oauth_accounts")
}

model AuditLog {
  id String @id @default(cuid())

  actorId String?
  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  action String
  entityType String
  entityId String?

  reason String?
  before Json?
  after Json?
  metadata Json?

  ipAddress String?
  userAgent String?

  creadoEn DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([creadoEn])
  @@map("audit_logs")
}

enum EstadoDocumentos {
  FALTAN_DOCUMENTOS
  DOCUMENTOS_CARGADOS
}

enum EstadoCredito {
  ACTIVO
  CANCELADO
}

enum FrecuenciaPago {
  MENSUAL
  QUINCENAL_5_20
  QUINCENAL_10_25
  QUINCENAL_15_30
}

enum TipoAmortizacion {
  AMORTIZACION_FIJA
  SOLO_INTERES
}

enum TipoEventoFinanciero {
  CUOTA_PROGRAMADA
  ABONO_CAPITAL
}

enum EstadoEventoFinanciero {
  PENDIENTE
  ATRASADO
  MORA
  PAGADO
  CANCELADO_POR_ABONO
}

enum ProveedorArchivo {
  GOOGLE_DRIVE
  LOCAL
  S3
  OTRO
}
